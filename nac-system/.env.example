# ── PostgreSQL ──
POSTGRES_DB=nac_db
POSTGRES_USER=nac_admin
POSTGRES_PASSWORD=change_me_in_production

# ── Redis ──
REDIS_PASSWORD=change_me_in_production

# ── FastAPI ──
DATABASE_URL=postgresql+asyncpg://nac_admin:change_me_in_production@postgres:5432/nac_db
REDIS_URL=redis://:change_me_in_production@redis:6379/0
SECRET_KEY=change_me_random_secret_key

# ── FreeRADIUS ──
# FreeRADIUS clients.conf'taki "secret" ile eşleşmeli.
# Geliştirme ortamı için "testing123" kullanılabilir (clients.conf'ta da aynı değer var).
# Production'da mutlaka güçlü bir değerle değiştirin ve clients.conf'u güncelleyin.
RADIUS_SECRET=testing123

# ── Rate Limiting ──
MAX_AUTH_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=300
